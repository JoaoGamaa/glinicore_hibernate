    <parameter name="SISTEMA" class="java.lang.String"/>
    <parameter name="TITULO" class="java.lang.String"/>
    <field name="descricao" class="java.lang.String"/>
    <field name="quantidade" class="java.lang.Long"/>
    <field name="valorTotalFormatado" class="java.lang.String"/>
    <title><band height="54"><textField><reportElement x="0" y="0" width="360" height="24"/><textElement><font size="16" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{TITULO}]]></textFieldExpression></textField><textField><reportElement x="0" y="28" width="360" height="18"/><textFieldExpression><![CDATA[$P{SISTEMA} + " - Emitido em " + new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></textFieldExpression></textField></band></title>
    <columnHeader><band height="22"><staticText><reportElement x="0" y="0" width="300" height="20"/><textElement><font isBold="true"/></textElement><text><![CDATA[Descricao]]></text></staticText><staticText><reportElement x="300" y="0" width="100" height="20"/><textElement><font isBold="true"/></textElement><text><![CDATA[Quantidade]]></text></staticText><staticText><reportElement x="400" y="0" width="155" height="20"/><textElement><font isBold="true"/></textElement><text><![CDATA[Valor total]]></text></staticText></band></columnHeader>
    <detail><band height="18"><textField><reportElement x="0" y="0" width="300" height="16"/><textFieldExpression><![CDATA[$F{descricao}]]></textFieldExpression></textField><textField><reportElement x="300" y="0" width="100" height="16"/><textFieldExpression><![CDATA[$F{quantidade} == null ? "" : String.valueOf($F{quantidade})]]></textFieldExpression></textField><textField><reportElement x="400" y="0" width="155" height="16"/><textFieldExpression><![CDATA[$F{valorTotalFormatado}]]></textFieldExpression></textField></band></detail>
    <pageFooter><band height="20"><textField><reportElement x="455" y="0" width="100" height="18"/><textFieldExpression><![CDATA["Pagina " + $V{PAGE_NUMBER}]]></textFieldExpression></textField></band></pageFooter>
