    <title><band height="110"><staticText><reportElement x="0" y="0" width="360" height="24"/><textElement><font size="16" isBold="true"/></textElement><text><![CDATA[Relatorio do Prontuario]]></text></staticText><textField><reportElement x="0" y="28" width="500" height="18"/><textFieldExpression><![CDATA[$P{SISTEMA} + " - Emitido em " + new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></textFieldExpression></textField><textField><reportElement x="0" y="52" width="500" height="18"/><textFieldExpression><![CDATA["Paciente: " + $P{PACIENTE} + " | CPF: " + $P{CPF}]]></textFieldExpression></textField><textField><reportElement x="0" y="72" width="500" height="18"/><textFieldExpression><![CDATA["Telefone: " + $P{TELEFONE} + " | E-mail: " + $P{EMAIL}]]></textFieldExpression></textField><textField><reportElement x="0" y="92" width="500" height="18"/><textFieldExpression><![CDATA["Nascimento: " + $P{DATA_NASCIMENTO} + " | Endereco: " + $P{ENDERECO}]]></textFieldExpression></textField></band></title>
